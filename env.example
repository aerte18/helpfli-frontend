# Frontend environment variables
# Skopiuj ten plik do .env.local i uzupeĹ‚nij wartoĹ›ci

# API URL - opcjonalnie, jeĹ›li nie ustawione, uĹĽywa proxy z vite.config.js (port 5000)
# W produkcji ustaw na peĹ‚ny URL backendu, np. https://api.helpfli.app
# VITE_API_URL=http://localhost:5000

# Stripe Publishable Key (pobierz z Stripe Dashboard)
# Test key zaczyna siÄ™ od pk_test_, production key od pk_live_
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_51XXXXYOURKEY

# VAPID Public Key dla Web Push Notifications
# Wygeneruj: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=BDUMMY_PUBLIC

# WĹ‚Ä…cz/wyĹ‚Ä…cz Socket.IO (domyĹ›lnie: true)
# Ustaw na 'false' aby wyĹ‚Ä…czyÄ‡ real-time features
# VITE_ENABLE_SOCKET=true

# Sentry DSN dla error tracking (opcjonalne)
# VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Gateway AI Base URL (domyĹ›lnie: http://localhost:7070)
# VITE_GATEWAY_AI_BASE=http://localhost:7070























